# =============================================================================
# Frontend Development Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Development Mode (LOCAL DEVELOPMENT ONLY!)
# -----------------------------------------------------------------------------
# ⚠️  NOTE: You don't need to create this file anymore!
# The frontend now automatically reads DEV_MODE from the root .env file.
#
# Simply set DEV_MODE=true in the root .env file and both backend
# and frontend will use it.
#
# This file is kept for reference only and for manual overrides if needed.
# 
# VITE_DEV_MODE bypasses the login UI for rapid local development
# ⚠️  WARNING: NEVER enable this in staging or production!
# 
# When enabled:
#   - Login page is skipped automatically
#   - Mock admin user is used (dev@deeptempo.ai)
#   - All permissions granted
#   - Console shows dev mode warnings
#
# To manually override (optional):
#   1. Copy to .env.development: cp env.development.example .env.development
#   2. Set VITE_DEV_MODE=true below
#   3. Restart the frontend dev server
#
# See ../DEV_MODE.md for full details
# VITE_DEV_MODE=true

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# These are typically set automatically by Vite, but can be overridden here
# VITE_API_URL=http://localhost:6987

